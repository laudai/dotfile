
# ===============================================================
# Subject: SSH personal settings
# This section of ssh config settings for user only has been added from the dotfile project automatically.
Host *
	User ec2-user
    ServerAliveInterval 120
	IdentityFile {The key path}
	# workaround for missing the terminfo to the host lack of xterm-ghostty
	# https://ghostty.org/docs/help/terminfo
	SetEnv TERM=xterm-256color

Host github.com
	Hostname ssh.github.com
	Port 443
	IdentityFile {The key path}
# ===============================================================

