# Uhis file has been auto-generated by i3-config-wizard(1).
# It will not be overwritten, so edit it as you like.
#
# Should you change your keyboard layout some time, delete
# this file and re-run i3-config-wizard(1).
#

# i3 config file (v4)
#
# Please see https://i3wm.org/docs/userguide.html for a complete reference!

# ─── Variables ────────────────────────────────────────────────────────────────

# set
# set the mod to super key (Mod1 as alt key)
set $mod Mod4
# set the defualt key arrow as vim-alike
set $up k
set $down j
set $left h
set $right l
#set $Maximum_ws <span foreground="#AB274F">Maximum</span>
set $Maximum_ws Maximum
set $refresh_i3status killall -SIGUSR1 i3status

# workspace
# Define names for default workspaces for which we configure key bindings later on.
# We use variables to avoid repeating the names in multiple places.
# NOTE: need to remove the double quotation for the i3-resurrect
set $ws1 1:
set $ws2 2:
set $ws3 3:
set $ws4 4:
set $ws5 5:
set $ws6 6:
set $ws7 7:
set $ws8 8:
set $ws9 9:♥
set $ws10 10:

# render monitor display
set $LAPTOP_INTERNAL_OUTPUT "eDP-1"
set $EXTERNAL_OUTPUT_PRIMARY "HDMI-2"
set $EXTERNAL_OUTPUT_SECONDARY "DP-1-3"
set $xauto xrandr --auto

# source https://wiki.archlinux.org/title/I3
set $Locker loginctl lock-session

set $i3_resurrect i3-resurrect

# ─── Appearance ───────────────────────────────────────────────────────────────

# This font is widely installed, provides lots of unicode glyphs, right-to-left
# text rendering and scalability on retina/hidpi displays (thanks to pango).
#font pango:DejaVu Sans Mono 10
font pango:JetBrainsMono NL Nerd Font 10

# set the container default setting
default_border normal 3
default_floating_border normal 3

# add some gaps for the polybar show in the fullscreen mode
gaps top 26

# reference: https://gitlab.com/dwt1/dotfiles/-/blob/master/.config/i3/config
# colour
# class                 border  backgr. text    indic.   child_border
client.focused          #556064 #556064 #80FFF9 #FDF6E3
client.focused_inactive #2F3DAF #2F3D44 #AD69AF #454948
client.unfocused        #2F3D44 #2F3D44 #AD69AF #454948
client.urgent           #CB4B16 #FDF6E3 #AD69AF #268BD2
client.placeholder      #000000 #0c0c0c #ffffff #000000
client.background       #2B2C2B

# ─── Bar ──────────────────────────────────────────────────────────────────────

# bar

# Start i3bar to display a workspace bar (plus the system information i3status
# finds out, if available)
# use the polybar, remove the default bar
# example:
#bar {
#    status_command i3status
#    position top
#}
bar {
    status_command i3status
    #strip_workspace_numbers yes
    #binding_mode_indicator yes
    font pango:JetBrainsMono NL Nerd Font 12
    mode hide
    hidden_state hide
    tray_output none
    position bottom
}

# ─── Window Rules ─────────────────────────────────────────────────────────────

# xprop criteria area
#    switch to workspace with urgent window automatically
for_window [urgent=latest] focus
for_window [class="firefox_firefox" title="(?i)35.*PressPlay"] move container to workspace $ws5, workspace $ws5
for_window [class="Gnome-terminal"] resize set width 40 ppt
for_window [class="com.mitchellh.ghostty"] resize set width 40 ppt

# ─── Autostart ────────────────────────────────────────────────────────────────

# exec
# Start XDG autostart .desktop files using dex. See also
# https://wiki.archlinux.org/index.php/XDG_Autostart
exec --no-startup-id dex --autostart --environment i3

# The combination of xss-lock, nm-applet and pactl is a popular choice, so
# they are included here as an example. Modify as you see fit.

# xss-lock grabs a logind suspend inhibit lock and will use i3lock to lock the
# screen before suspend. Use loginctl lock-session to lock your screen.
# --transfer-sleep-lock ensures screen locks before suspend.
# lock.sh: dpms 60s after lock, restore 300s on unlock.
exec --no-startup-id xss-lock --transfer-sleep-lock -- ~/.dotfile/scripts/i3/lock.sh
# set DPMS: standby 300s, suspend 300s, off 300s (5 min after idle)
# X11 default: 600 600 600 (10 min)
exec --no-startup-id xset dpms 300 300 300

# NetworkManager is the most popular way to manage wireless networks on Linux,
# and nm-applet is a desktop environment-independent system tray GUI for it.
exec --no-startup-id nm-applet --indicator
# run fcitx5 input method in daemon mode
exec --no-startup-id fcitx5 -d
# bluetooth manager
exec --no-startup-id blueman-applet
# launcher
exec --no-startup-id vicinae server
# dunst Lightweight and customizable notification daemon
exec --no-startup-id dunst
# picom (compositor), nitrogen (wallpaper), conky (system monitor)
# Launched sequentially via script to avoid race conditions on X11 startup
exec --no-startup-id ~/.dotfile/scripts/i3/autostart.sh
# auto render the monitor xrandr
exec_always --no-startup-id ~/.dotfile/scripts/i3/render_i3_monitor.sh
# run polybar as status bar
exec_always --no-startup-id ~/.dotfile/scripts/i3/polybar_launch.sh
# run i3/sway script to toggle between last windows
exec i3-swap-focus

# ─── Keybindings: General ─────────────────────────────────────────────────────

# keybindings

# start a terminal
bindsym $mod+Return exec i3-sensible-terminal
bindsym Ctrl+mod1+t exec i3-sensible-terminal

# kill focused window
bindsym $mod+Shift+q kill
bindsym mod1+Shift+q kill
bindsym mod1+Shift+w kill
bindsym mod1+w kill
# click the right mouse button on tittle to kill the window
bindsym button3 kill

# start dmenu (a program launcher)
#bindsym $mod+d exec --no-startup-id dmenu_run
#bindsym mod1+space exec --no-startup-id dmenu_run
bindsym $mod+d exec --no-startup-id vicinae vicinae://toggle
bindsym mod1+space exec --no-startup-id vicinae vicinae://toggle
bindsym $mod+Ctrl+Shift+c exec --no-startup-id vicinae vicinae://extensions/vicinae/clipboard/history
# other launcher
bindsym Shift+mod1+1 exec --no-startup-id vicinae vicinae://toggle
bindsym Shift+mod1+2 exec "rofi -modes run,window,drun,keys -show run"
bindsym Shift+mod1+3 exec --no-startup-id dmenu_run
# A more modern dmenu replacement is rofi:
# bindcode $mod+40 exec "rofi -modi drun,run -show drun"
# There also is i3-dmenu-desktop which only displays applications shipping a
# .desktop file. It is a wrapper around dmenu, so you need that installed.
# bindcode $mod+40 exec --no-startup-id i3-dmenu-desktop

# ─── Keybindings: Navigation ─────────────────────────────────────────────────

# change focus
bindsym $mod+$left focus left
bindsym $mod+$down focus down
bindsym $mod+$up focus up
bindsym $mod+$right focus right
# alternatively, you can use the cursor keys:
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right
# run i3/sway script to toggle between last windows
bindsym mod1+Tab exec pkill -USR1 -F "${XDG_RUNTIME_DIR}/swap_focus.pid"

# move focused window
bindsym $mod+Shift+$left move left
bindsym $mod+Shift+$down move down
bindsym $mod+Shift+$up move up
bindsym $mod+Shift+$right move right
# alternatively, you can use the cursor keys:
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# move the focused window as floating window to top/bottom/left/right
bindsym $mod+mod1+$left  exec --no-startup-id ~/.dotfile/scripts/i3/i3-horizontal-vertical-split.sh left
bindsym $mod+mod1+$right exec --no-startup-id ~/.dotfile/scripts/i3/i3-horizontal-vertical-split.sh right
bindsym $mod+mod1+$up    exec --no-startup-id ~/.dotfile/scripts/i3/i3-horizontal-vertical-split.sh top
bindsym $mod+mod1+$down  exec --no-startup-id ~/.dotfile/scripts/i3/i3-horizontal-vertical-split.sh bottom
# reset the floating window
bindsym $mod+mod1+0 exec --no-startup-id ~/.dotfile/scripts/i3/i3-horizontal-vertical-split.sh reset

# focus the parent/child container
bindsym $mod+p focus parent
bindsym $mod+c focus child

# change focus between tiling / floating windows
bindsym $mod+space focus mode_toggle

# ─── Keybindings: Workspace ──────────────────────────────────────────────────

# switch to workspace
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10
bindsym $mod+m workspace $Maximum_ws
# switch to workspace with ctrl key
bindsym Ctrl+1 workspace number $ws1
bindsym Ctrl+2 workspace number $ws2
bindsym Ctrl+3 workspace number $ws3
bindsym Ctrl+4 workspace number $ws4
bindsym Ctrl+5 workspace number $ws5
bindsym Ctrl+6 workspace number $ws6
bindsym Ctrl+7 workspace number $ws7
bindsym Ctrl+8 workspace number $ws8
bindsym Ctrl+9 workspace number $ws9

# move focused container to workspace
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10
bindsym $mod+Shift+m move container to workspace $Maximum_ws
# move focused container to workspace and swithch to the workspace with ctrl/control
bindsym $mod+Ctrl+Shift+1 move container to workspace number $ws1; workspace $ws1
bindsym $mod+Ctrl+Shift+2 move container to workspace number $ws2; workspace $ws2
bindsym $mod+Ctrl+Shift+3 move container to workspace number $ws3; workspace $ws3
bindsym $mod+Ctrl+Shift+4 move container to workspace number $ws4; workspace $ws4
bindsym $mod+Ctrl+Shift+5 move container to workspace number $ws5; workspace $ws5
bindsym $mod+Ctrl+Shift+6 move container to workspace number $ws6; workspace $ws6
bindsym $mod+Ctrl+Shift+7 move container to workspace number $ws7; workspace $ws6
bindsym $mod+Ctrl+Shift+8 move container to workspace number $ws8; workspace $ws8
bindsym $mod+Ctrl+Shift+9 move container to workspace number $ws9; workspace $ws9
bindsym $mod+Ctrl+Shift+0 move container to workspace number $ws10; workspace $ws10
bindsym $mod+Ctrl+Shift+m move container to workspace $Maximum_ws; workspace $Maximum_ws
# move focused container to prev/next workspace
#bindsym Ctrl+Shift+mod1+$right move container to workspace next; workspace next
#bindsym Ctrl+Shift+mod1+$left move container to workspace prev; workspace prev
bindsym Ctrl+Shift+mod1+$right exec ~/.dotfile/scripts/i3/move_i3_container_or_workspace.sh 1 move_container
bindsym Ctrl+Shift+mod1+$left exec ~/.dotfile/scripts/i3/move_i3_container_or_workspace.sh -1 move_container

# Automatic back-and-forth when switching to the current workspace
workspace_auto_back_and_forth yes
# switch between the current and the previously focused one
bindsym $mod+b workspace back_and_forth
bindsym $mod+Shift+b move container to workspace back_and_forth

# move focused workspace
bindsym Ctrl+mod1+Right workspace next_on_output
bindsym Ctrl+mod1+Left workspace prev_on_output
bindsym Ctrl+mod1+$right workspace next_on_output
bindsym Ctrl+mod1+$left workspace prev_on_output
#bindsym Ctrl+mod1+$right exec ~/.dotfile/scripts/i3/move_i3_container_or_workspace.sh 1
#bindsym Ctrl+mod1+$left exec ~/.dotfile/scripts/i3/move_i3_container_or_workspace.sh -1

# move focused worksapce to primary output
bindsym Ctrl+mod1+p move workspace to output primary; workspace back_and_forth

# ─── Keybindings: Layout ─────────────────────────────────────────────────────

# enter fullscreen mode for the focused container
bindsym $mod+f fullscreen toggle
# change container layout (stacked, tabbed, toggle split)
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split
bindsym $mod+percent layout splith; exec notify-send 'split horizontally'
bindsym $mod+apostrophe layout splitv; exec notify-send 'split vertically'
# split in horizontal/vertical orientation
bindsym Ctrl+mod1+percent split h; exec notify-send 'title horizontally'
bindsym Ctrl+mod1+apostrophe split v; exec notify-send 'title vertically'

# toggle tiling / floating
bindsym $mod+Shift+f floating toggle
bindsym $mod+Shift+space floating toggle

# Use Mouse+$mod to drag floating windows to their wanted position
floating_modifier $mod
# move tiling windows via drag & drop by left-clicking into the title bar,
# or left-clicking anywhere into the window while holding the floating modifier.
tiling_drag modifier titlebar

bindsym Shift+mod1+minus resize set width 30 ppt
bindsym Shift+mod1+plus resize set width 50 ppt

# mouse
# use Mouse+$Mod to drag floating windows to their wanted position
floating_modifier $mod

# scratchpad
# move the currently focused window to the scratchpad
bindsym $mod+minus move scratchpad
bindsym $mod+n move scratchpad
# Show the next scratchpad window or hide the focused scratchpad window.
# If there are multiple scratchpad windows, this command cycles through them.
bindsym $mod+Shift+minus scratchpad show, floating toggle
bindsym $mod+Shift+n scratchpad show, floating toggle

# ─── Keybindings: Volume ──────────────────────────────────────────────────────

# Use pactl to adjust volume in PulseAudio.
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +5% && $refresh_i3status
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -5% && $refresh_i3status
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3status
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle && $refresh_i3status

# ─── Keybindings: Apps ────────────────────────────────────────────────────────

# APP keybindings

# toggle bar
bindsym Shift+mod1+b bar mode toggle

# dunst notification daemon
bindsym mod1+a exec dunstctl history-pop
bindsym mod1+c exec dunstctl close-all
# toggle conky
bindsym mod1+y exec --no-startup-id pgrep -x conky && killall conky || conky -d
# flameshot
bindsym $mod+Shift+s exec --no-startup-id flatpak run org.flameshot.Flameshot gui

# ─── Keybindings: System ──────────────────────────────────────────────────────

# system keybinding
# reload the configuration file
bindsym $mod+Shift+c reload
# restart i3 inplace (preserves your layout/session, can be used to upgrade i3)
# had created exectued file, will render the monitor output
bindsym $mod+Shift+r restart
# exit i3 (logs you out of your X session)
bindsym $mod+Ctrl+Shift+l exec "i3-nagbar -t warning -m 'You pressed the exit shortcut. Do you really want to exit i3? This will end your X session.' -B 'Yes, exit i3' 'i3-msg exit'"
# render the monitor manually when no output on eDP-1
bindsym Ctrl+Shift+mod1+x exec --no-startup-id xrandr --auto

# ─── Mode: Resize ────────────────────────────────────────────────────────────

# mode

# resize window (you can also use the mouse for that)
mode "resize" {
	# These bindings trigger as soon as you enter the resize mode

    bindsym $up resize grow width 10 px or 10 ppt; resize grow height 10 px or 10 ppt; move position center
    bindsym $down resize shrink width 10 px or 10 ppt; resize shrink height 10 px or 10 ppt; move position center
    bindsym $right resize grow width 10 px or 10 ppt; resize grow height 10 px or 10 ppt
    bindsym $left resize shrink width 10 px or 10 ppt; resize shrink height 10 px or 10 ppt

    # press = to grow
    bindsym equal resize grow width 10 px or 10 ppt; resize grow height 10 px or 10 ppt; move position center
    # press - to shrink
    bindsym minus resize shrink width 10 px or 10 ppt; resize shrink height 10 px or 10 ppt; move position center

    bindsym Up resize grow width 4 px or 4 ppt; resize grow height 4 px or 4 ppt
    bindsym Down resize shrink width 4 px or 4 ppt; resize shrink height 4 px or 4 ppt
    bindsym Left resize shrink width 4 px or 4 ppt
    bindsym Right resize grow width 4 px or 4 ppt

    # back to normal: Enter or Escape or $mod+r
    bindsym Return mode "default"
    bindsym Escape mode "default"
    bindsym space mode "default"
    bindsym Q mode "default"
    bindsym $mod+r mode "default"
}
bindsym $mod+r mode "resize"

# ─── Mode: System (lock/logout/suspend/reboot/shutdown) ──────────────────────

set $mode_system System (q) lock, (l) logout session, (s) suspend, (h) hibernate, (r) reboot, (Shift+s) shutdown (Press esc/enter/space to quit!)
mode "$mode_system" {
    bindsym q exec --no-startup-id xrandr --auto; exec --no-startup-id $Locker, mode "default"
    bindsym l exec --no-startup-id xrandr --auto; exec --no-startup-id i3-msg exit, mode "default"
    bindsym s exec --no-startup-id xrandr --auto; exec --no-startup-id $Locker && systemctl suspend, mode "default"
    # TODO to fix hibernate issue
    #bindsym h exec --no-startup-id $Locker && systemctl hibernate, mode "default"
    bindsym r exec --no-startup-id systemctl reboot, mode "default"
    bindsym Shift+s exec --no-startup-id systemctl poweroff -i, mode "default"

    # back to normal: Enter or Escape
    bindsym Return mode "default"
    bindsym space mode "default"
    bindsym Escape mode "default"
}
bindsym Ctrl+mod1+q mode "$mode_system"

# ─── Mode: Monitor Display ───────────────────────────────────────────────────

set $monitor_display Config the monitor display (0)Close other monitor/(1)2 External monitor/(2)Primary External monitor with Internal DP (Press esc/enter/space/q to quit!)
mode "$monitor_display" {
    bindsym 0 exec --no-startup-id $xauto && xrandr --output $LAPTOP_INTERNAL_OUTPUT --off --output $EXTERNAL_OUTPUT_SECONDARY --off, mode "default"
    bindsym 1 exec --no-startup-id $xauto && xrandr --output $EXTERNAL_OUTPUT_PRIMARY --primary --auto --output $EXTERNAL_OUTPUT_SECONDARY --right-of $EXTERNAL_OUTPUT_PRIMARY, mode "default"
    bindsym 2 exec --no-startup-id $xauto && xrandr --output $EXTERNAL_OUTPUT_PRIMARY --primary --auto --output $LAPTOP_INTERNAL_OUTPUT --right-of $EXTERNAL_OUTPUT_PRIMARY, mode "default"

    # back to normal: Enter/Space/Escape/q/Ctrl+mod1+i
    bindsym Return mode "default"
    bindsym space mode "default"
    bindsym Escape mode "default"
    bindsym Ctrl+mod1+i mode "default"
    bindsym q mode "default"
}
bindsym Ctrl+mod1+i mode "$monitor_display"

# ─── Mode: Border ────────────────────────────────────────────────────────────

# reference: https://gitlab.com/dwt1/dotfiles/-/blob/master/.config/i3/config
# change the border
set $border_changer System [u] none, [t] 3 pixel(in normal mode) [n] normal (Press return/space/q/esc to quit!)
mode "$border_changer" {
    bindsym u border none
    bindsym t border normal 3; exec notify-send 'set 3 px border to modify container size by mouse.'
    bindsym n border normal

    # back to normal: Enter or Escape
    bindsym Return mode "default"
    bindsym space mode "default"
    bindsym q mode "default"
    bindsym Escape mode "default"
    bindsym Ctrl+Shift+mod1+b mode "default"
}
bindsym Ctrl+Shift+mod1+b mode "$border_changer"

# ─── Mode: Gaps ──────────────────────────────────────────────────────────────

# Press $mod+Shift+g to enter the gap mode.
# Choose o or i for modifying outer/inner gaps.
# Press one of + / - (in-/decrement for current workspace)
# or 0 (remove gaps for current workspace). If you also press Shift
# with these keys, the change will be global for all workspaces.
set $mode_gaps Gaps: (o) outer, (i) inner
set $mode_gaps_outer Outer Gaps: +|-|0 (local), Shift + +|-|0 (global)
set $mode_gaps_inner Inner Gaps: +|-|0 (local), Shift + +|-|0 (global)
mode "$mode_gaps" {
    bindsym o      mode "$mode_gaps_outer"
    bindsym i      mode "$mode_gaps_inner"

    bindsym Return mode "default"
    bindsym space mode "default"
    bindsym q mode "default"
    bindsym Escape mode "default"
}
mode "$mode_gaps_inner" {
    bindsym plus  gaps inner current plus 5
    bindsym minus gaps inner current minus 5
    bindsym 0     gaps inner current set 0

    bindsym Shift+plus  gaps inner all plus 5
    bindsym Shift+minus gaps inner all minus 5
    bindsym Shift+0     gaps inner all set 0

    bindsym Return mode "default"
    bindsym space mode "default"
    bindsym q mode "default"
    bindsym Escape mode "default"
}
mode "$mode_gaps_outer" {
    bindsym plus  gaps outer current plus 5
    bindsym minus gaps outer current minus 5
    bindsym 0     gaps outer current set 0

    bindsym Shift+plus  gaps outer all plus 5
    bindsym Shift+minus gaps outer all minus 5
    bindsym Shift+0     gaps outer all set 0

    bindsym Return mode "default"
    bindsym space mode "default"
    bindsym q mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+Shift+g mode "$mode_gaps"

# ─── Mode: i3-resurrect (save/restore workspace) ─────────────────────────────

# i3-resurrect
# reference: https://github.com/JonnyHaystack/i3-resurrect
# Save workspace mode.
mode "save" {
  bindsym 1 exec "$i3_resurrect save -w $ws1 --swallow=class,instance,title"
  bindsym 2 exec "$i3_resurrect save -w $ws2 --swallow=class,instance,title"
  bindsym 3 exec "$i3_resurrect save -w $ws3 --swallow=class,instance,title"
  bindsym 4 exec "$i3_resurrect save -w $ws4 --swallow=class,instance,title"
  bindsym 5 exec "$i3_resurrect save -w $ws5 --swallow=class,instance,title"
  bindsym 6 exec "$i3_resurrect save -w $ws6 --swallow=class,instance,title"
  bindsym 7 exec "$i3_resurrect save -w $ws7 --swallow=class,instance,title"
  bindsym 8 exec "$i3_resurrect save -w $ws8 --swallow=class,instance,title"
  bindsym 9 exec "$i3_resurrect save -w $ws9 --swallow=class,instance,title"
  bindsym 0 exec "$i3_resurrect save -w $ws10 --swallow=class,instance,title"

  # Back to normal: Enter, Escape, or q
  bindsym Return mode "default"
  bindsym Escape mode "default"
  bindsym q mode "default"
  bindsym mod1+equal mode "default"
}
bindsym mod1+equal mode "save"

# Restore workspace mode.
mode "restore" {
  bindsym 1 exec "$i3_resurrect restore -w $ws1"
  bindsym 2 exec "$i3_resurrect restore -w $ws2"
  bindsym 3 exec "$i3_resurrect restore -w $ws3"
  bindsym 4 exec "$i3_resurrect restore -w $ws4"
  bindsym 5 exec "$i3_resurrect restore -w $ws5"
  bindsym 6 exec "$i3_resurrect restore -w $ws6"
  bindsym 7 exec "$i3_resurrect restore -w $ws7"
  bindsym 8 exec "$i3_resurrect restore -w $ws8"
  bindsym 9 exec "$i3_resurrect restore -w $ws9"
  bindsym 0 exec "$i3_resurrect restore -w $ws10"

  bindsym $mod+1 exec "$i3_resurrect restore -w $ws1 --programs-only"
  bindsym $mod+2 exec "$i3_resurrect restore -w $ws2 --programs-only"
  bindsym $mod+3 exec "$i3_resurrect restore -w $ws3 --programs-only"
  bindsym $mod+4 exec "$i3_resurrect restore -w $ws4 --programs-only"
  bindsym $mod+5 exec "$i3_resurrect restore -w $ws5 --programs-only"
  bindsym $mod+6 exec "$i3_resurrect restore -w $ws6 --programs-only"
  bindsym $mod+7 exec "$i3_resurrect restore -w $ws7 --programs-only"
  bindsym $mod+8 exec "$i3_resurrect restore -w $ws8 --programs-only"
  bindsym $mod+9 exec "$i3_resurrect restore -w $ws9 --programs-only"
  bindsym $mod+0 exec "$i3_resurrect restore -w $ws10 --programs-only"

  bindsym mod1+1 exec "$i3_resurrect restore -w $ws1 --layout-only"
  bindsym mod1+2 exec "$i3_resurrect restore -w $ws2 --layout-only"
  bindsym mod1+3 exec "$i3_resurrect restore -w $ws3 --layout-only"
  bindsym mod1+4 exec "$i3_resurrect restore -w $ws4 --layout-only"
  bindsym mod1+5 exec "$i3_resurrect restore -w $ws5 --layout-only"
  bindsym mod1+6 exec "$i3_resurrect restore -w $ws6 --layout-only"
  bindsym mod1+7 exec "$i3_resurrect restore -w $ws7 --layout-only"
  bindsym mod1+8 exec "$i3_resurrect restore -w $ws8 --layout-only"
  bindsym mod1+9 exec "$i3_resurrect restore -w $ws9 --layout-only"
  bindsym mod1+0 exec "$i3_resurrect restore -w $ws10 --layout-only"

  # Back to normal: Enter, Escape, or q
  bindsym Return mode "default"
  bindsym Escape mode "default"
  bindsym q mode "default"
  bindsym mod1+minus mode "default"
}
bindsym mod1+minus mode "restore"

# run i3-resurrect via dmenu
bindsym mod1+s exec ~/.dotfile/scripts/i3/i3-resurrect-dmenu.sh
