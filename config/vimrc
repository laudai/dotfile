" autocmds

" jump to last known cursor position when editing a file
augroup vimrcEx
  au!
  autocmd FileType text setlocal textwidth=78
  autocmd BufReadPost *
    \ if line("'\"") >= 1 && line("'\"") <= line("$") |
    \   exe "normal! g`\"" |
    \ endif
augroup END

" file templates
autocmd BufNewFile *.sh 0put =\"#!/usr/bin/env bash\<nl>\"|$
autocmd BufNewFile *.sh 1put =\"# Author : laudai\<nl>\"|$
autocmd BufNewFile *.sh 2put =\"\<nl>\"|$

autocmd BufNewFile *.py 0put =\"#!/usr/bin/env python\<nl>\"|$
autocmd BufNewFile *.py 1put =\"# Author : laudai\<nl>\"|$
autocmd BufNewFile *.py 2put =\"\<nl>\"|$

" toggle relative line numbers and cursorline based on focus/mode
augroup displaytoggle
  autocmd!
  autocmd BufEnter,FocusGained,InsertLeave * set relativenumber
    \| set cursorline
    \| highlight LineNr ctermfg=darkgray
  autocmd BufLeave,FocusLost,InsertEnter   * set norelativenumber
    \| set nocursorline
    \| highlight LineNr ctermfg=yellow
augroup END
