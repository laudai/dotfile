" general
set nocompatible
set background=dark
set t_Co=256
if has('termguicolors')
  set termguicolors
endif
set number
set relativenumber
set autoindent
set laststatus=2
set ruler
set history=200
set pastetoggle=<F7>
set clipboard^=unnamedplus,unnamed
set undofile
set autochdir
set autoread
set nrformats=bin,hex,alpha
filetype plugin indent on

" tabs & indentation
set shiftwidth=4
set softtabstop=4
set tabstop=4

" search
set hlsearch
set incsearch
set ignorecase
set smartcase

" wildmenu (command-line completion)
set wildmenu
set wildmode=full

" highlight
highlight CursorLine cterm=bold,underline ctermbg=black ctermfg=None

" abbreviations
iab [] []()<left><left><left>


