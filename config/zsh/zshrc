# keybindings
# Key notation: ^[ and \e both mean ESC (0x1b) — terminal sends ESC+key for Alt+key
# Debug keypress:
#   shell:   Ctrl-v then press key (shows raw sequence inline)
#   terminal: cat -v (shows escape sequences)
#   TTY:     showkey -a (root, not in X/Wayland)
#   X11:     xev (keypress events) / xmodmap -pke (all mappings)
#   Wayland: wev (keypress events)
bindkey '^[\' autosuggest-toggle # alt-\
bindkey -s '^[i' '^Uexit^M' # alt-i
bindkey '^P' history-substring-search-up
bindkey '^N' history-substring-search-down
bindkey -M menuselect 'j' vi-down-line-or-history
bindkey -M menuselect 'k' vi-up-line-or-history
bindkey -M menuselect 'l' vi-forward-char
bindkey -M menuselect 'h' vi-backward-char
bindkey '^Y^Y' undo # bind ^Y^Y undo like emacs ^Y keymaps
bindkey '^[l' forward-word # alt-l
bindkey '^[h' backward-word # alt-h
bindkey '^[.' insert-last-word # alt-.
bindkey '^[/' _run-help-clean # alt-/
# How to switch comfortably to vi command mode on the zsh command line?
# https://superuser.com/questions/351499/how-to-switch-comfortably-to-vi-command-mode-on-the-zsh-command-line
bindkey -M viins 'jk' vi-cmd-mode
# vi/emacs mode toggle keybindings
bindkey -M viins '^[e' _select-emacs  # alt-e: switch to emacs mode (from vi insert)
bindkey -M vicmd '^[e' _select-emacs  # alt-e: switch to emacs mode (from vi command)
bindkey -M emacs '^[v' _select-vi     # alt-v: switch to vi mode (from emacs)
bindkey -M viins '\ec' _select-emacs  # alt-c: switch to emacs mode (from vi insert)
bindkey -M emacs '\ec' _select-vi     # alt-c: switch to vi mode (from emacs)
# vi command mode shortcuts (space+e/a as end/beginning of line)
bindkey -M vicmd " e" end-of-line         # space-e: jump to end of line
bindkey -M vicmd " a" beginning-of-line   # space-a: jump to beginning of line
# zsh-navigation-tools keybindings
zle -N znt-cd-widget
bindkey "^B" znt-cd-widget    # ctrl-b: znt directory navigator
zle -N znt-kill-widget
bindkey "^Y" znt-kill-widget  # ctrl-y: znt process killer
# Set up fzf key bindings and fuzzy completion
# fzf 0.48.0+ supports --zsh; older versions use separate source files
if fzf --zsh &>/dev/null; then
  source <(fzf --zsh)
else
  [ -f /usr/share/doc/fzf/examples/key-bindings.zsh ] && source /usr/share/doc/fzf/examples/key-bindings.zsh
  [ -f /usr/share/doc/fzf/examples/completion.zsh ] && source /usr/share/doc/fzf/examples/completion.zsh
fi
# Rebind fzf cd widget from alt-c to alt-p (avoid conflict with vi/emacs toggle)
bindkey -M emacs '\ep' fzf-cd-widget  # alt-p: fzf directory picker (emacs mode)
bindkey -M viins '\ep' fzf-cd-widget  # alt-p: fzf directory picker (vi insert)
bindkey -M vicmd '\ep' fzf-cd-widget  # alt-p: fzf directory picker (vi command)
# pet query keybindings
bindkey '^s' pet-snippet-search # ctrl-s
# kiro agent selector
bindkey '^k' kiro-agent-select # ctrl-k
# Bind Ctrl+U to .kill-whole-line instead of vi-kill-line:
# 1. Deletes entire line regardless of insert-mode entry point (vi-kill-line
#    does nothing after A, unlike vim's <C-g>u<C-u> remap in .vimrc)
# 2. Dot prefix bypasses vi-mode plugin's clipcopy wrapper that clears
#    system clipboard with empty CUTBUFFER
bindkey '^U' .kill-whole-line
