# source
# Modular config files. Order matters — functions/widgets must be defined
# before init hooks (oh-my-zsh, starship, fzf) below.
ZSH_CONFIG="$HOME/.dotfile/config/zsh"

# Cross-platform modules (ordered)
typeset -a zsh_modules=(
  functions.zsh   # Utility functions (must be first — others depend on it)
  aliases.zsh     # Command aliases
  aitool.zsh      # Local AI daemons (Anytype + agentmemory) control
)

# OS-specific module
case "$OSTYPE" in
  darwin*) zsh_modules+=(functions-macos.zsh) ;;
  linux*)  zsh_modules+=(functions-linux.zsh) ;;
esac

for m in $zsh_modules; do
  source "$ZSH_CONFIG/$m"
done
unset ZSH_CONFIG zsh_modules m


