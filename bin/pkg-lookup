#!/usr/bin/env zsh
# =============================================================================
# pkg-lookup — Check if packages exist in brew, apt, flatpak, snap
#
# Usage:
#   pkg-lookup <name> [name...]           Check all sources
#   pkg-lookup --pkg-mgr-only <name>...   Check brew/apt only
#
# When brew/apt is not installed locally, falls back to HTTP API.
# Fallback apt source: packages.ubuntu.com (noble = 24.04 LTS)
# Fallback flatpak source: Flathub API (https://flathub.org/api/v2/search)
# Fallback snap source: Snap Store API (https://api.snapcraft.io/v2/snaps/info)
# =============================================================================
set -eo pipefail

# --- Flag parsing ---
pkg_mgr_only=false
pkgs=()
for arg in "$@"; do
	case "$arg" in
		--pkg-mgr-only) pkg_mgr_only=true ;;
		-h|--help)
			echo "Usage: pkg-lookup [--pkg-mgr-only] <name> [name...]"
			exit 0
			;;
		*) pkgs+=("$arg") ;;
	esac
done

if [[ ${#pkgs[@]} -eq 0 ]]; then
	echo "Usage: pkg-lookup [--pkg-mgr-only] <name> [name...]"
	exit 0
fi

# --- Load brew index (one-time cost) ---
if command -v brew >/dev/null; then
	export HOMEBREW_NO_AUTO_UPDATE=1
	brew_formulae=$(brew formulae 2>/dev/null)
	brew_casks=$(brew casks 2>/dev/null)
else
	brew_formulae=$(curl -fsSL --max-time 10 "https://formulae.brew.sh/api/formula.json" 2>/dev/null | jq -r '.[].name')
	brew_casks=$(curl -fsSL --max-time 10 "https://formulae.brew.sh/api/cask.json" 2>/dev/null | jq -r '.[].token')
fi

function brew_check() {
	echo "$brew_formulae" | grep -Fcx "$1" >/dev/null && { echo "formula"; return; }
	echo "$brew_casks" | grep -Fcx "$1" >/dev/null && { echo "cask"; return; }
	echo ""
}

# --- apt check ---
function apt_check() {
	if command -v apt-cache >/dev/null; then
		apt-cache show "$1" >/dev/null 2>&1 && { echo "yes"; return; }
	else
		# API fallback: packages.ubuntu.com (noble = 24.04 LTS)
		local found
		found=$(curl -fsSL --max-time 10 "https://packages.ubuntu.com/search?keywords=$1&searchon=names&exact=1&suite=noble&section=all" 2>/dev/null \
			| grep -o "Package $1" | head -1 || true)
		[[ -n "$found" ]] && { echo "yes"; return; }
	fi
	echo ""
}

# --- flatpak check ---
# Match strategy: exact last-segment match OR first word of pkg (dash-split, >=4 chars) is prefix of any segment
function flatpak_check() {
	local awk_filter='
	BEGIN { has_dash = index(pkg, "-"); split(pkg, parts, "-"); prefix=tolower(parts[1]) }
	{
		p=tolower(pkg); id=tolower($0)
		n=split(id, segs, ".")
		if (segs[n] == p) {print; exit}
		for(i=1;i<=n;i++) if (segs[i] == p) {print; exit}
		if (has_dash && length(prefix) >= 3) {
			for(i=1;i<=n;i++) if (index(segs[i], prefix) == 1) {print; exit}
		}
	}'
	if command -v flatpak >/dev/null; then
		local result
		result=$(flatpak search --columns=application "$1" 2>/dev/null \
			| awk -v pkg="$1" "$awk_filter" || true)
		[[ -n "$result" ]] && { echo "$result"; return; }
	else
		# Flathub API fallback
		local app_id
		app_id=$(curl -fsSL --max-time 5 "https://flathub.org/api/v2/search" \
			-H "Content-Type: application/json" \
			-d "{\"query\":\"$1\",\"locale\":\"en\"}" 2>/dev/null \
			| jq -r '.hits[].app_id' 2>/dev/null \
			| awk -v pkg="$1" "$awk_filter" || true)
		[[ -n "$app_id" ]] && { echo "$app_id"; return; }
	fi
	echo ""
}

# --- snap check ---
function snap_check() {
	if command -v snap >/dev/null; then
		snap info "$1" >/dev/null 2>&1 && { echo "yes"; return; }
	else
		# Snap Store API fallback
		local response
		response=$(curl -fsSL --max-time 5 \
			-H "Snap-Device-Series: 16" \
			"https://api.snapcraft.io/v2/snaps/info/$1" 2>/dev/null || true)
		local name
		name=$(echo "$response" | jq -r '.name // empty' 2>/dev/null || true)
		[[ -n "$name" ]] && { echo "yes"; return; }
	fi
	echo ""
}

# --- check single package, write result to temp file ---
function check_pkg() {
	local pkg="$1" tmpdir="$2"
	local brew_result apt_result flatpak_result snap_result

	brew_result=$(brew_check "$pkg")
	apt_result=$(apt_check "$pkg")

	if [[ "$pkg_mgr_only" == false ]]; then
		flatpak_result=$(flatpak_check "$pkg")
		snap_result=$(snap_check "$pkg")
	fi

	if [[ "$pkg_mgr_only" == true ]]; then
		printf "%-25s  brew: %-10s  apt: %s\n" \
			"$pkg" \
			"${brew_result:-✗}" \
			"${apt_result:-✗}" > "$tmpdir/$pkg"
	else
		printf "%-25s  brew: %-10s  apt: %-5s  flatpak: %-40s  snap: %s\n" \
			"$pkg" \
			"${brew_result:-✗}" \
			"${apt_result:-✗}" \
			"${flatpak_result:-✗}" \
			"${snap_result:-✗}" > "$tmpdir/$pkg"
	fi
}

# --- main ---
tmpdir=$(mktemp -d)
trap "rm -rf $tmpdir" EXIT  # Clean up temp files on exit

# Parallel lookups (brew uses local grep, already fast)
for pkg in "${pkgs[@]}"; do
	check_pkg "$pkg" "$tmpdir" &
done
wait

for pkg in "${pkgs[@]}"; do
	cat "$tmpdir/$pkg"
done

if [[ "$pkg_mgr_only" == false ]]; then
	echo ""
	echo "Note: flatpak/snap results are fuzzy-matched and may not reflect exact package names."
fi
